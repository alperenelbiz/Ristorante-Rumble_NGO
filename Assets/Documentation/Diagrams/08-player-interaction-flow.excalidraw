    {
      "type": "text", "version": 2, "versionNonce": 302, "isDeleted": false, "id": "rpc_list_title",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "x": 340, "y": 786, "strokeColor": "#1971c2", "backgroundColor": "transparent",
      "width": 330, "height": 16, "seed": 302, "groupIds": [], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 12, "fontFamily": 1, "text": "[Rpc(SendTo.Server)] Calls", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "[Rpc(SendTo.Server)] Calls", "lineHeight": 1.25
    },
    {
      "type": "text", "version": 2, "versionNonce": 303, "isDeleted": false, "id": "rpc_list_body",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "x": 340, "y": 808, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "width": 330, "height": 110, "seed": 303, "groupIds": [], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 10, "fontFamily": 1, "text": "1. StartCookingRpc(stationNetId, recipeIndex)\n   -> from RecipeSelectUI selection\n\n2. CollectDishRpc(stationNetId)\n   -> from station.IsDone\n\n3. ClearStationRpc(stationNetId)\n   -> from station.IsBurned\n\n4. PlaceDishRpc(counterNetId, recipeIndex)\n   -> from carrying dish at counter\n\n5. PickUpIngredientRpc(ingredientIndex)\n   -> from empty hands at source\n\n6. DropItemRpc()  -> from Q key while carrying", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "1. StartCookingRpc(stationNetId, recipeIndex)\n   -> from RecipeSelectUI selection\n\n2. CollectDishRpc(stationNetId)\n   -> from station.IsDone\n\n3. ClearStationRpc(stationNetId)\n   -> from station.IsBurned\n\n4. PlaceDishRpc(counterNetId, recipeIndex)\n   -> from carrying dish at counter\n\n5. PickUpIngredientRpc(ingredientIndex)\n   -> from empty hands at source\n\n6. DropItemRpc()  -> from Q key while carrying", "lineHeight": 1.25
    },

