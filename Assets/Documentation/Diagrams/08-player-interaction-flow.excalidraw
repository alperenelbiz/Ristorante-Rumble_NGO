    },
    {
      "type": "text", "version": 2, "versionNonce": 812, "isDeleted": false, "id": "val_helpers_body",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
