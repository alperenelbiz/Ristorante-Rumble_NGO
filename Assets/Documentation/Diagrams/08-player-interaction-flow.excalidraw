      "width": 330, "height": 65, "seed": 812, "groupIds": [], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 10, "fontFamily": 1, "text": "ValidateTeam(senderClientId, stationTeamId)\n  -> TeamManager.Instance.GetPlayerTeam(clientId)\n  -> Returns false if team mismatch\n\nValidateProximity(targetPos)\n  -> dist <= interactRange * PROXIMITY_TOLERANCE\n  -> interactRange=2.5f, tolerance=1.5f => max 3.75f", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "ValidateTeam(senderClientId, stationTeamId)\n  -> TeamManager.Instance.GetPlayerTeam(clientId)\n  -> Returns false if team mismatch\n\nValidateProximity(targetPos)\n  -> dist <= interactRange * PROXIMITY_TOLERANCE\n  -> interactRange=2.5f, tolerance=1.5f => max 3.75f", "lineHeight": 1.25
    },


