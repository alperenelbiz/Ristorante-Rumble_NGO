    {
      "type": "text", "version": 2, "versionNonce": 411, "isDeleted": false, "id": "val_sc_title",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "x": 800, "y": 124, "strokeColor": "#1971c2", "backgroundColor": "transparent",
      "width": 300, "height": 16, "seed": 411, "groupIds": [], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 12, "fontFamily": 1, "text": "StartCookingRpc Validation", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "StartCookingRpc Validation", "lineHeight": 1.25
    },
    {
      "type": "text", "version": 2, "versionNonce": 412, "isDeleted": false, "id": "val_sc_body",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "x": 800, "y": 145, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "width": 300, "height": 110, "seed": 412, "groupIds": [], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 10, "fontFamily": 1, "text": "1. Resolve stationNetId -> NetworkObject\n2. GetComponent<CookingStation>()\n3. station.IsIdle? (CookingStatus.Idle)\n4. ValidateTeam(OwnerClientId, station.TeamId)\n   -> TeamManager.GetPlayerTeam()\n5. ValidateProximity(station.transform.position)\n   -> dist <= interactRange * 1.5f\n6. station.StartCooking(recipeIndex)\n   -> Checks requiredStation type match\n   -> Sets Status = Cooking, progress = 0\n   -> GameEvents.CookingStarted()", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "1. Resolve stationNetId -> NetworkObject\n2. GetComponent<CookingStation>()\n3. station.IsIdle? (CookingStatus.Idle)\n4. ValidateTeam(OwnerClientId, station.TeamId)\n   -> TeamManager.GetPlayerTeam()\n5. ValidateProximity(station.transform.position)\n   -> dist <= interactRange * 1.5f\n6. station.StartCooking(recipeIndex)\n   -> Checks requiredStation type match\n   -> Sets Status = Cooking, progress = 0\n   -> GameEvents.CookingStarted()", "lineHeight": 1.25
    },


