      "width": 205, "height": 125, "seed": 512, "groupIds": [], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 11, "fontFamily": 1, "text": "1. Host leaves game\n       |\n2. NetworkManager shuts\n   down on all clients\n       |\n3. OnNetworkDespawn fires\n   on GameManager\n       |\n4. Only unsubscribes from\n   OnValueChanged  ONLY\n       |\n5. Clients stuck on\n   game scene, no cleanup\n   frozen UI  BUG", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "1. Host leaves game\n       |\n2. NetworkManager shuts\n   down on all clients\n       |\n3. OnNetworkDespawn fires\n   on GameManager\n       |\n4. Only unsubscribes from\n   OnValueChanged  ONLY\n       |\n5. Clients stuck on\n   game scene, no cleanup\n   frozen UI  BUG", "lineHeight": 1.25
    },

