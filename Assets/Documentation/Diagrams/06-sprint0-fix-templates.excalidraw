    {
      "type": "text", "version": 1, "versionNonce": 112, "isDeleted": false, "id": "m1_before_flow",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "x": 38, "y": 168, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "width": 205, "height": 195, "seed": 112, "groupIds": [], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 11, "fontFamily": 1, "text": "1. Player joins mid-game\n       |\n2. OnClientConnected fires\n       |\n3. PlayerSpawnManager\n   spawns player\n       |\n4. GameManager.OnNetworkSpawn\n   runs on CLIENT\n       |\n5. CurrentState = DayPhase\n   via NetworkVariable  OK\n       |\n6. OnValueChanged NOT fired\n   for initial value!  FAIL\n       |\n7. UI/Camera/Lighting\n   stuck in WaitingForPlayers", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "1. Player joins mid-game\n       |\n2. OnClientConnected fires\n       |\n3. PlayerSpawnManager\n   spawns player\n       |\n4. GameManager.OnNetworkSpawn\n   runs on CLIENT\n       |\n5. CurrentState = DayPhase\n   via NetworkVariable  OK\n       |\n6. OnValueChanged NOT fired\n   for initial value!  FAIL\n       |\n7. UI/Camera/Lighting\n   stuck in WaitingForPlayers", "lineHeight": 1.25
    },

