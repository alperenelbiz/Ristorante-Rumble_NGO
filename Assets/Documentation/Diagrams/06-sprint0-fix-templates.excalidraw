      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "x": 38, "y": 854, "strokeColor": "#495057", "backgroundColor": "transparent",
      "width": 400, "height": 14, "seed": 431, "groupIds": [], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 10, "fontFamily": 3, "text": "// PlayerSpawnManager.cs  OnClientDisconnected() — replace body:", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "// PlayerSpawnManager.cs  OnClientDisconnected() — replace body:", "lineHeight": 1.25
    },
    {
      "type": "text", "version": 1, "versionNonce": 432, "isDeleted": false, "id": "m4_code",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "x": 38, "y": 872, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "width": 460, "height": 115, "seed": 432, "groupIds": [], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 12, "fontFamily": 3, "text": "if (spawnedPlayers.TryGetValue(clientId, out var netObj))\n{\n    if (netObj != null)\n    {\n        // M4 FIX: log carried item before despawn\n        var interaction = netObj.GetComponent<PlayerInteraction>();\n        if (interaction != null && interaction.IsCarrying)\n            Debug.LogWarning($\"[SpawnManager] Player {clientId} \"\n                + $\"disconnected carrying: {interaction.CarriedItem.Value}\");\n        netObj.Despawn();\n    }\n    spawnedPlayers.Remove(clientId);\n}", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "if (spawnedPlayers.TryGetValue(clientId, out var netObj))\n{\n    if (netObj != null)\n    {\n        // M4 FIX: log carried item before despawn\n        var interaction = netObj.GetComponent<PlayerInteraction>();\n        if (interaction != null && interaction.IsCarrying)\n            Debug.LogWarning($\"[SpawnManager] Player {clientId} \"\n                + $\"disconnected carrying: {interaction.CarriedItem.Value}\");\n        netObj.Despawn();\n    }\n    spawnedPlayers.Remove(clientId);\n}", "lineHeight": 1.25
    },
    {
