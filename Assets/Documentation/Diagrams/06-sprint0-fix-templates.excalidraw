      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 11, "fontFamily": 1, "text": "1. Round ends\n       |\n2. DayPhaseCleanup fires\n       |\n3. CookingStation clears  OK\n   ServingCounter clears  OK\n       |\n4. PlayerInteraction\n   NOT subscribed!  MISS\n       |\n5. CarriedItem unchanged\n       |\n6. Player starts new round\n   carrying old dish  BUG", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "1. Round ends\n       |\n2. DayPhaseCleanup fires\n       |\n3. CookingStation clears  OK\n   ServingCounter clears  OK\n       |\n4. PlayerInteraction\n   NOT subscribed!  MISS\n       |\n5. CarriedItem unchanged\n       |\n6. Player starts new round\n   carrying old dish  BUG", "lineHeight": 1.25
    },

