      "fontSize": 10, "fontFamily": 3, "text": "// PlayerInteraction.cs — subscribe to cleanup event:", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "// PlayerInteraction.cs — subscribe to cleanup event:", "lineHeight": 1.25
    },
    {
      "type": "text", "version": 1, "versionNonce": 332, "isDeleted": false, "id": "m3_code",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "x": 1058, "y": 342, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "width": 460, "height": 145, "seed": 332, "groupIds": [], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 12, "fontFamily": 3, "text": "// In OnNetworkSpawn — add after existing code:\nif (IsServer)\n    GameEvents.OnDayPhaseCleanup += ClearCarriedItem;\n\n// In OnNetworkDespawn — add:\nif (IsServer)\n    GameEvents.OnDayPhaseCleanup -= ClearCarriedItem;\n\n// New method:\nprivate void ClearCarriedItem()\n{\n    if (!IsServer) return;\n    CarriedItem.Value = CarriedItemData.Empty;\n}", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "// In OnNetworkSpawn — add after existing code:\nif (IsServer)\n    GameEvents.OnDayPhaseCleanup += ClearCarriedItem;\n\n// In OnNetworkDespawn — add:\nif (IsServer)\n    GameEvents.OnDayPhaseCleanup -= ClearCarriedItem;\n\n// New method:\nprivate void ClearCarriedItem()\n{\n    if (!IsServer) return;\n    CarriedItem.Value = CarriedItemData.Empty;\n}", "lineHeight": 1.25
    },
    {
      "type": "text", "version": 1, "versionNonce": 333, "isDeleted": false, "id": "m3_note",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "x": 1050, "y": 503, "strokeColor": "#e67700", "backgroundColor": "transparent",
      "width": 475, "height": 28, "seed": 333, "groupIds": [], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 10, "fontFamily": 1, "text": "Note: Only server writes to CarriedItem (WritePermission.Server).\nSubscribe only on server to avoid client-side no-op subscriptions.", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "Note: Only server writes to CarriedItem (WritePermission.Server).\nSubscribe only on server to avoid client-side no-op subscriptions.", "lineHeight": 1.25
    },


