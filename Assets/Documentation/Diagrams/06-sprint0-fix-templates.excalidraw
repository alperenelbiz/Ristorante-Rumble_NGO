      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "x": 548, "y": 854, "strokeColor": "#495057", "backgroundColor": "transparent",
      "width": 400, "height": 14, "seed": 531, "groupIds": [], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 10, "fontFamily": 3, "text": "// GameManager.cs  OnNetworkDespawn() — add client recovery:", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "// GameManager.cs  OnNetworkDespawn() — add client recovery:", "lineHeight": 1.25
    },
    {
      "type": "text", "version": 1, "versionNonce": 532, "isDeleted": false, "id": "m5_code",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "x": 548, "y": 872, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "width": 460, "height": 100, "seed": 532, "groupIds": [], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 12, "fontFamily": 3, "text": "public override void OnNetworkDespawn()\n{\n    CurrentState.OnValueChanged -= OnStateValueChanged;\n    PhaseTimer.OnValueChanged -= OnTimerValueChanged;\n\n    // M5 FIX: host disconnect -> return clients to menu\n    if (!IsServer)\n    {\n        Debug.LogWarning(\"[GameManager] Host disconnected, returning to menu\");\n        GameEvents.ResetAll();\n        SceneController.ReturnToMenu();\n    }\n}", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "public override void OnNetworkDespawn()\n{\n    CurrentState.OnValueChanged -= OnStateValueChanged;\n    PhaseTimer.OnValueChanged -= OnTimerValueChanged;\n\n    // M5 FIX: host disconnect -> return clients to menu\n    if (!IsServer)\n    {\n        Debug.LogWarning(\"[GameManager] Host disconnected, returning to menu\");\n        GameEvents.ResetAll();\n        SceneController.ReturnToMenu();\n    }\n}", "lineHeight": 1.25
    },
    {
      "type": "text", "version": 1, "versionNonce": 533, "isDeleted": false, "id": "m5_note",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "x": 540, "y": 988, "strokeColor": "#e67700", "backgroundColor": "transparent",
      "width": 475, "height": 42, "seed": 533, "groupIds": [], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 10, "fontFamily": 1, "text": "GameEvents.ResetAll() nulls all delegates (line 41 in GameEvents.cs).\nSceneController.ReturnToMenu() loads the lobby/menu scene.\nTogether they ensure a full clean reset on all remaining clients.", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "GameEvents.ResetAll() nulls all delegates (line 41 in GameEvents.cs).\nSceneController.ReturnToMenu() loads the lobby/menu scene.\nTogether they ensure a full clean reset on all remaining clients.", "lineHeight": 1.25
    },


