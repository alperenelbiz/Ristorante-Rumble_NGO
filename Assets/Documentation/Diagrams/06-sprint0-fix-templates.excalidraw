      "verticalAlign": "top", "containerId": null, "originalText": "// GameManager.cs  OnNetworkSpawn()  add after line ~55:", "lineHeight": 1.25
    },
    {
      "type": "text", "version": 1, "versionNonce": 132, "isDeleted": false, "id": "m1_code",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
      "angle": 0, "x": 38, "y": 402, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "width": 460, "height": 80, "seed": 132, "groupIds": [], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 12, "fontFamily": 3, "text": "if (IsServer)\n    CurrentState.Value = GameState.WaitingForPlayers;\nelse\n{\n    clientLocalTimer = PhaseTimer.Value;\n    // M1 FIX: CLIENT catch up to current state\n    OnStateValueChanged(GameState.WaitingForPlayers, CurrentState.Value);\n}", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "if (IsServer)\n    CurrentState.Value = GameState.WaitingForPlayers;\nelse\n{\n    clientLocalTimer = PhaseTimer.Value;\n    // M1 FIX: CLIENT catch up to current state\n    OnStateValueChanged(GameState.WaitingForPlayers, CurrentState.Value);\n}", "lineHeight": 1.25
    },
    {
      "type": "text", "version": 1, "versionNonce": 133, "isDeleted": false, "id": "m1_note",
