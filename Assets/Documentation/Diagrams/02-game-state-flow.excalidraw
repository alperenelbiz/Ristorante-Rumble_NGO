    {
      "type": "text", "version": 1, "versionNonce": 407, "isDeleted": false, "id": "panel_camera_lighting",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 80,
      "angle": 0, "x": 1085, "y": 660, "strokeColor": "#495057", "backgroundColor": "transparent",
      "width": 285, "height": 70, "seed": 407, "groupIds": ["grp_camera"], "frameId": null, "roundness": null,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "fontSize": 10, "fontFamily": 1, "text": "LightingManager (runs in parallel):\n  Day:   color(1.0, 0.95, 0.8)  intensity=1.0\n  Night: color(0.2, 0.2, 0.4)   intensity=0.3\n  Transition: Color.Lerp + Mathf.Lerp per frame\n  Speed: transitionSpeed (default 2f)\n  Uses directionalLight reference", "textAlign": "left",
      "verticalAlign": "top", "containerId": null, "originalText": "LightingManager (runs in parallel):\n  Day:   color(1.0, 0.95, 0.8)  intensity=1.0\n  Night: color(0.2, 0.2, 0.4)   intensity=0.3\n  Transition: Color.Lerp + Mathf.Lerp per frame\n  Speed: transitionSpeed (default 2f)\n  Uses directionalLight reference", "lineHeight": 1.25
    },



