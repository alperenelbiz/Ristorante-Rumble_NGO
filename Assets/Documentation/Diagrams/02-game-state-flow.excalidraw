      "locked": false,
      "fontSize": 10,
      "fontFamily": 1,
      "text": "Trigger: OnGameStateChanged event\n  WaitingForPlayers/Starting/DayPhase -> ActivateDayCamera()\n  Transition/NightPhase -> ActivateNightCamera()\n\nCursor: Unlocked+Visible (day) / Locked+Hidden (night)\nFollow target set via CameraManager.SetFollowTarget()",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Trigger: OnGameStateChanged event\n  WaitingForPlayers/Starting/DayPhase -> ActivateDayCamera()\n  Transition/NightPhase -> ActivateNightCamera()\n\nCursor: Unlocked+Visible (day) / Locked+Hidden (night)\nFollow target set via CameraManager.SetFollowTarget()",
      "lineHeight": 1.25,
      "index": "b0J",
      "autoResize": true
    },
    {
      "type": "text",
      "version": 103,
      "versionNonce": 978002236,
      "isDeleted": false,
      "id": "panel_camera_lighting",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 80,
      "angle": 0,
      "x": 1085.1877618712556,
