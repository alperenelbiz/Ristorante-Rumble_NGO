      "groupIds": [
        "grp_camera"
      ],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1776348575442,
      "link": null,
      "locked": false,
      "fontSize": 10,
      "fontFamily": 1,
      "text": "LightingManager (runs in parallel):\n  Day:   color(1.0, 0.95, 0.8)  intensity=1.0\n  Night: color(0.2, 0.2, 0.4)   intensity=0.3\n  Transition: Color.Lerp + Mathf.Lerp per frame\n  Speed: transitionSpeed (default 2f)\n  Uses directionalLight reference",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "LightingManager (runs in parallel):\n  Day:   color(1.0, 0.95, 0.8)  intensity=1.0\n  Night: color(0.2, 0.2, 0.4)   intensity=0.3\n  Transition: Color.Lerp + Mathf.Lerp per frame\n  Speed: transitionSpeed (default 2f)\n  Uses directionalLight reference",
      "lineHeight": 1.25,
      "index": "b0K",
      "autoResize": true
    },
